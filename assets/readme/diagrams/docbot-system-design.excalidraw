      "link": null,
      "locked": false
    },
    {
      "id": "deploy-text",
      "type": "text",
      "x": 740,
      "y": 1180,
      "width": 540,
      "height": 188,
      "angle": 0,
      "strokeColor": "#4c1d95",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1062,
      "version": 1,
      "versionNonce": 162,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "deploy - Vercel Production\n\n1. backend Vercel project, root=backend, preset=Other\n2. frontend Vercel project, root=frontend, preset=Next.js\n3. Supabase Postgres + Upstash Redis + Qdrant Cloud\n4. QDRANT_CLIENT_API_ENDPOINT + QDRANT_CLIENT_API_KEY\n5. DOCBOT_ENABLE_DENSE_RETRIEVAL=1\n6. run ingest_qdrant_cloud.py locally to populate Qdrant Cloud",
      "fontSize": 18,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "deploy - Vercel Production\n\n1. backend Vercel project, root=backend, preset=Other\n2. frontend Vercel project, root=frontend, preset=Next.js\n3. Supabase Postgres + Upstash Redis + Qdrant Cloud\n4. QDRANT_CLIENT_API_ENDPOINT + QDRANT_CLIENT_API_KEY\n5. DOCBOT_ENABLE_DENSE_RETRIEVAL=1\n6. run ingest_qdrant_cloud.py locally to populate Qdrant Cloud",
      "lineHeight": 1.25,
      "baseline": 182
    },
    {
      "id": "env-note",
      "type": "text",
      "x": 40,
      "y": 1435,
      "width": 1100,
      "height": 48,
      "angle": 0,
      "strokeColor": "#475569",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1063,
      "version": 1,
      "versionNonce": 163,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Production selection: the backend uses Qdrant Cloud when QDRANT_CLIENT_API_ENDPOINT and QDRANT_CLIENT_API_KEY are set; otherwise it falls back to local Qdrant host/port.",
      "fontSize": 17,
      "fontFamily": 1,
      "textAlign": "left",
