    {
      "id": "local-text",
      "type": "text",
      "x": 70,
      "y": 1180,
      "width": 520,
      "height": 188,
      "angle": 0,
      "strokeColor": "#064e3b",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1060,
      "version": 1,
      "versionNonce": 160,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "origin/main - Local Development\n\n1. docker compose up -d\n2. backend/.env points at localhost services\n3. uvicorn backend.api.main:app --reload --port 8000\n4. frontend/.env.local -> NEXT_PUBLIC_API_URL=http://localhost:8000\n5. npm run dev on localhost:3000\n6. optional ingest_sample_data.py into local Qdrant",
      "fontSize": 18,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "origin/main - Local Development\n\n1. docker compose up -d\n2. backend/.env points at localhost services\n3. uvicorn backend.api.main:app --reload --port 8000\n4. frontend/.env.local -> NEXT_PUBLIC_API_URL=http://localhost:8000\n5. npm run dev on localhost:3000\n6. optional ingest_sample_data.py into local Qdrant",
      "lineHeight": 1.25,
      "baseline": 182
    },
    {
      "id": "deploy-box",
      "type": "rectangle",
      "x": 710,
      "y": 1155,
      "width": 600,
      "height": 250,
      "angle": 0,
      "strokeColor": "#7c3aed",
      "backgroundColor": "#f5f3ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
