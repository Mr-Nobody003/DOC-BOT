# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_GENERATION=qwen/qwen3-30b-a3b
LLM_MODEL_VALIDATION=google/gemma-3-12b-it
LLM_MODEL_QUERY=google/gemma-3-12b-it

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=medical_db
POSTGRES_USER=medical_user
POSTGRES_PASSWORD=medical_password

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=medical_evidence

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=medical-artifacts
MINIO_USE_SSL=false

# Evidence thresholds
EVIDENCE_MIN_CHUNKS=2
EVIDENCE_MIN_AVG_SCORE=0.55
CONFIDENCE_MIN_RESPONSE=0.45

# LangGraph checkpoints: memory | redis
CHECKPOINT_BACKEND=memory

# Observability
LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_ENDPOINT=

# Optional other providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
